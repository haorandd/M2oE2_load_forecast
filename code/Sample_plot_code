def load_scaler_meta(path: str):
    path = resolve_existing_file(path, patterns=["*.json"])
    with open(path, "r", encoding="utf-8") as f:
        meta = json.load(f)
    return meta, path


def get_load_denorm_mode(meta: dict):
    if ("load_min" in meta) and ("load_max" in meta):
        return "minmax"
    if "load_scale" in meta:
        return "scale"
    raise ValueError(
        f"[ERR] Cannot infer load denorm mode from scaler meta. "
        f"Available keys: {list(meta.keys())}"
    )


def denorm_load(x, meta: dict):
    mode = get_load_denorm_mode(meta)

    if mode == "minmax":
        load_min = float(meta["load_min"])
        load_max = float(meta["load_max"])
        return x * (load_max - load_min) + load_min

    # mode == "scale"
    load_scale = float(meta["load_scale"])
    offset_keys = ["load_center", "load_mean", "load_mu", "load_offset", "load_bias"]
    offset = 0.0
    for k in offset_keys:
        if k in meta:
            offset = float(meta[k])
            break
    return x * load_scale + offset


def denorm_load_std(std, meta: dict):
    mode = get_load_denorm_mode(meta)

    if mode == "minmax":
        return std * (float(meta["load_max"]) - float(meta["load_min"]))

    return std * float(meta["load_scale"])


