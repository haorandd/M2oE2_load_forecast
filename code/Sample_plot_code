def main():
    xlsx_path = resolve_existing_file(XLSX_PATH, patterns=["*.xlsx"])
    meta, scaler_path = load_scaler_meta(SCALER_META_JSON)

    print(f"[INFO] Using XLSX        : {xlsx_path}")
    print(f"[INFO] Using scaler meta : {scaler_path}")

    df_xlsx = pd.read_excel(xlsx_path)
    model_base = pick_model_name_by_keys(df_xlsx, BASE_MODEL_KEYS)
    if model_base is None:
        raise ValueError("[ERR] Cannot find a valid BASE model_name in XLSX.")

    print(f"[INFO] model_base picked: {model_base}")

    out_dir = make_unique_outdir(OUT_DIR_BASE, xlsx_path)
    xlsx_tag = os.path.splitext(os.path.basename(xlsx_path))[0]
    print(f"[INFO] Output folder: {out_dir}")

    hourly, week_start_map, temp_col, load_col, csv_path_used = load_hourly_df(CSV_PATH, TARGET_XFMR)

    summary = {
        "xfmr": int(TARGET_XFMR),
        "xlsx": os.path.basename(xlsx_path),
        "scaler_meta": os.path.basename(scaler_path),
        "csv": os.path.basename(csv_path_used),
        "model_base": model_base,
        "params": {
            "Q": Q,
            "TOP_N_SEARCH": TOP_N_SEARCH,
            "TOP_K": TOP_K,
            "USE_BOUNDARY": USE_BOUNDARY,
            "USE_WITHIN": USE_WITHIN,
            "ENCODER_LEN_WEEKS": ENCODER_LEN_WEEKS,
        },
        "results": {}
    }

    # --------------------------------------------------------
    # (1) Temperature sudden change Top3
    # --------------------------------------------------------
    cand_temp = find_top_sudden_weeks_from_hourly(
        hourly,
        temp_col,
        q=Q,
        top_n=TOP_N_SEARCH,
        use_boundary=USE_BOUNDARY,
        use_within=USE_WITHIN,
    )

    temp_picks = pick_topk_valid_candidate_weeks(
        cand_temp,
        df_xlsx,
        model_base,
        ENCODER_LEN_WEEKS,
        TOP_K,
    )

    summary["results"]["temp_top3"] = []
    if not temp_picks:
        print("[WARN] No valid TEMP shock weeks found.")
    else:
        for rank, item in enumerate(temp_picks, start=1):
            w = item["week_idx"]
            ts = item["week_start_ts"]
            sidx = item["sample_index"]
            metric = item["shock_metric"]

            print(f"[TEMP TOP{rank}] week_idx={w}, week_start={ts}, sample_index={sidx}, metric={metric:.4f}")
            png = plot_one_week(
                df_xlsx=df_xlsx,
                sample_index=sidx,
                decoder_week_start_ts=ts,
                tag=f"TEMP_SHOCK_rank{rank}_w{w}",
                out_dir=out_dir,
                meta=meta,
                load_unit=LOAD_UNIT,
                temp_unit=TEMP_UNIT,
                model_base=model_base,
                csv_path=csv_path_used,
                xfmr=TARGET_XFMR,
                xlsx_tag=xlsx_tag,
                save_fig=SAVE_FIG,
                show_fig=SHOW_FIG,
            )

            summary["results"]["temp_top3"].append({
                "rank": rank,
                "week_idx": int(w),
                "week_start_ts": str(pd.to_datetime(ts)),
                "sample_index": int(sidx),
                "shock_metric": float(metric),
                "png": os.path.basename(png) if png else None,
            })

    # --------------------------------------------------------
    # (2) Load sudden change Top3
    # --------------------------------------------------------
    summary["results"]["load_top3"] = []

    if load_col is not None:
        cand_load = find_top_sudden_weeks_from_hourly(
            hourly,
            load_col,
            q=Q,
            top_n=TOP_N_SEARCH,
            use_boundary=USE_BOUNDARY,
            use_within=USE_WITHIN,
        )

        load_picks = pick_topk_valid_candidate_weeks(
            cand_load,
            df_xlsx,
            model_base,
            ENCODER_LEN_WEEKS,
            TOP_K,
        )

        if not load_picks:
            print("[WARN] No valid LOAD shock weeks found from CSV.")
        else:
            for rank, item in enumerate(load_picks, start=1):
                w = item["week_idx"]
                ts = item["week_start_ts"]
                sidx = item["sample_index"]
                metric = item["shock_metric"]

                print(f"[LOAD TOP{rank}] week_idx={w}, week_start={ts}, sample_index={sidx}, metric={metric:.4f}")
                png = plot_one_week(
                    df_xlsx=df_xlsx,
                    sample_index=sidx,
                    decoder_week_start_ts=ts,
                    tag=f"LOAD_SHOCK_rank{rank}_w{w}",
                    out_dir=out_dir,
                    meta=meta,
                    load_unit=LOAD_UNIT,
                    temp_unit=TEMP_UNIT,
                    model_base=model_base,
                    csv_path=csv_path_used,
                    xfmr=TARGET_XFMR,
                    xlsx_tag=xlsx_tag,
                    save_fig=SAVE_FIG,
                    show_fig=SHOW_FIG,
                )

                summary["results"]["load_top3"].append({
                    "rank": rank,
                    "week_idx": int(w),
                    "week_start_ts": str(pd.to_datetime(ts)),
                    "sample_index": int(sidx),
                    "shock_metric": float(metric),
                    "png": os.path.basename(png) if png else None,
                })

    else:
        print("[INFO] CSV has no load column. Falling back to XLSX-based load shock...")
        df_shock = compute_load_shock_from_xlsx(df_xlsx, meta, model_base)

        if df_shock.empty:
            print("[WARN] XLSX-based load shock list is empty.")
        else:
            cnt = 0
            for i in range(min(len(df_shock), TOP_N_SEARCH)):
                sidx = int(df_shock.loc[i, "sample_index"])
                widx = int(sidx + ENCODER_LEN_WEEKS)

                hit = week_start_map[week_start_map["week_idx"] == widx]
                if hit.empty:
                    continue

                ts = pd.to_datetime(hit.iloc[0]["week_start_ts"])
                metric = float(df_shock.loc[i, "dL_metric"])

                cnt += 1
                print(f"[LOAD TOP{cnt} (XLSX)] week_idx={widx}, week_start={ts}, sample_index={sidx}, metric={metric:.4f}")

                png = plot_one_week(
                    df_xlsx=df_xlsx,
                    sample_index=sidx,
                    decoder_week_start_ts=ts,
                    tag=f"LOAD_SHOCK_rank{cnt}_XLSX_w{widx}",
                    out_dir=out_dir,
                    meta=meta,
                    load_unit=LOAD_UNIT,
                    temp_unit=TEMP_UNIT,
                    model_base=model_base,
                    csv_path=csv_path_used,
                    xfmr=TARGET_XFMR,
                    xlsx_tag=xlsx_tag,
                    save_fig=SAVE_FIG,
                    show_fig=SHOW_FIG,
                )

                summary["results"]["load_top3"].append({
                    "rank": cnt,
                    "week_idx": int(widx),
                    "week_start_ts": str(pd.to_datetime(ts)),
                    "sample_index": int(sidx),
                    "shock_metric": float(metric),
                    "png": os.path.basename(png) if png else None,
                })

                if cnt >= TOP_K:
                    break

    sum_path = os.path.join(out_dir, "selection_summary.json")
    with open(sum_path, "w", encoding="utf-8") as f:
        json.dump(summary, f, indent=2)

    print(f"[✓] Saved summary: {sum_path}")
    print("[DONE]")


if __name__ == "__main__":
    main()
