def resolve_existing_file(path: str, patterns=None):
    if os.path.exists(path):
        return path

    if patterns is None:
        patterns = ["*"]

    cands = []
    for pat in patterns:
        cands.extend(glob.glob(pat))

    cands = sorted(set(cands))
    if not cands:
        raise FileNotFoundError(f"[ERR] File not found: {path}")

    def score(p):
        name = os.path.basename(p).lower()
        s = 0
        if "v2" in name:
            s += 10
        if "blockexpert3" in name:
            s += 8
        if "raw24h" in name:
            s += 8
        if "topk2" in name:
            s += 6
        if "peakwarm150" in name:
            s += 6
        if "xfmrid" in name:
            s += 6
        if "base_only" in name:
            s += 4
        if "scaler_meta" in name:
            s += 4
        return s

    best = sorted(cands, key=score, reverse=True)[0]
    print(f"[WARN] Target file not found: {path}")
    print(f"[INFO] Auto-selected instead: {best}")
    return best


def make_unique_outdir(base_dir: str, xlsx_path: str):
    stem = os.path.splitext(os.path.basename(xlsx_path))[0]
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    out_dir = os.path.join(base_dir, f"{stem}__{ts}")
    os.makedirs(out_dir, exist_ok=True)
    return out_dir


def _guess_col(df, candidates):
    for c in candidates:
        if c in df.columns:
            return c
    return None


