# CSV parsing
# ============================================================
def load_hourly_df(csv_path: str, xfmr: int):
    csv_path = resolve_existing_file(csv_path, patterns=["*.csv"])
    df = pd.read_csv(csv_path)

    if "XFMR" not in df.columns:
        raise KeyError(f"[ERR] 'XFMR' column not found. Columns={df.columns.tolist()}")

    df = df[df["XFMR"] == xfmr].copy()
    if df.empty:
        raise ValueError(f"[ERR] No rows for XFMR={xfmr} in {csv_path}")

    date_col = _guess_col(df, ["DATE1", "DATE", "date", "Date"])
    hour_col = _guess_col(df, ["HOUR1", "HOUR", "hour", "Hour"])
    if date_col is None or hour_col is None:
        raise KeyError(
            f"[ERR] Cannot find date/hour columns. "
            f"Columns={df.columns.tolist()}"
        )

    df[date_col] = pd.to_datetime(df[date_col])
    df["ts"] = df[date_col] + pd.to_timedelta(df[hour_col].astype(int), unit="h")

    temp_col = _guess_col(df, ["TEMPERATURE", "TEMP", "Temperature", "temperature"])
    if temp_col is None:
        raise KeyError(f"[ERR] Cannot find temperature column. Columns={df.columns.tolist()}")

    load_col = _guess_col(df, [
        "LOAD", "Load", "LOAD_KW", "LOAD_AVG", "KW", "kW",
        "LOAD1", "LOAD_VALUE", "LOAD_MW", "MW", "P", "POWER", "P_KW"
    ])
    if load_col is None:
        for c in df.columns:
            if isinstance(c, str) and ("load" in c.lower()):
                load_col = c
                break

    agg_cols = {temp_col: "mean"}
    if load_col is not None:
        agg_cols[load_col] = "mean"

    hourly = (
        df.groupby("ts", as_index=False)
          .agg(agg_cols)
          .sort_values("ts")
          .reset_index(drop=True)
    )

    t0 = hourly["ts"].min()
    hourly["week_idx"] = ((hourly["ts"] - t0).dt.total_seconds() // (3600 * 168)).astype(int)
    week_start = hourly.groupby("week_idx")["ts"].min().rename("week_start_ts").reset_index()

    print(f"[CSV] XFMR {xfmr} time range: {hourly['ts'].min()} -> {hourly['ts'].max()}")
    print(f"[CSV] temp_col={temp_col} | load_col={load_col if load_col is not None else '(NOT FOUND)'}")

    return hourly, week_start, temp_col, load_col, csv_path


def load_temp_from_csv(csv_path: str, xfmr: int, start_ts: pd.Timestamp, periods: int):
    df = pd.read_csv(csv_path)
    df = df[df["XFMR"] == xfmr].copy()
    if df.empty:
        raise ValueError(f"[ERR] No rows for XFMR={xfmr} in {csv_path}")

    date_col = _guess_col(df, ["DATE1", "DATE", "date", "Date"])
    hour_col = _guess_col(df, ["HOUR1", "HOUR", "hour", "Hour"])
    temp_col = _guess_col(df, ["TEMPERATURE", "TEMP", "Temperature", "temperature"])
    if date_col is None or hour_col is None or temp_col is None:
        raise KeyError(f"[ERR] Cannot parse time/temp cols from CSV. Columns={df.columns.tolist()}")

    df[date_col] = pd.to_datetime(df[date_col])
    df["ts"] = df[date_col] + pd.to_timedelta(df[hour_col].astype(int), unit="h")

    temp_by_ts = df.groupby("ts", as_index=True)[temp_col].mean().sort_index()

    idx = pd.date_range(start=start_ts, periods=periods, freq="h")
    out = temp_by_ts.reindex(idx).ffill().bfill()
    return idx, out.to_numpy()


# ============================================================
# Sudden-week finder
# ============================================================
def find_top_sudden_weeks_from_hourly(
    hourly: pd.DataFrame,
    value_col: str,
    *,
    q: float = 0.95,
    top_n: int = 10,
    use_boundary: bool = True,
    use_within: bool = True,
):
    d = hourly[["ts", "week_idx", value_col]].copy()
    d["dV"] = d[value_col].diff().abs()

    rows = []
    for w, wk in d.groupby("week_idx", sort=True):
        if len(wk) < 2:
            continue

        dV_within = float(wk["dV"].max()) if use_within else 0.0

        if use_boundary and w > 0:
            first_pos = wk.index.min()
            dV_boundary = float(d.loc[first_pos, "dV"])
        else:
            dV_boundary = 0.0

        dV_metric = max(dV_within, dV_boundary)

        rows.append({
            "week_idx": int(w),
            "week_start_ts": wk["ts"].min(),
            "dV_metric": dV_metric,
            "dV_within": dV_within,
            "dV_boundary": dV_boundary,
        })

    wkdf = pd.DataFrame(rows)
    if wkdf.empty:
        return wkdf

    thr = wkdf["dV_metric"].quantile(q)
    cand = (
        wkdf[wkdf["dV_metric"] >= thr]
        .sort_values("dV_metric", ascending=False)
        .head(top_n)
        .reset_index(drop=True)
    )

    print(f"[SuddenWeeks] col={value_col} q={q} thr={thr:.4f} candidates={len(cand)}")
    return cand


def pick_topk_valid_candidate_weeks(
    cand_weeks: pd.DataFrame,
    df_xlsx: pd.DataFrame,
    model_base: str,
    encoder_len_weeks: int,
    top_k: int,
):
    picks = []
    if cand_weeks is None or cand_weeks.empty:
        return picks

    for i in range(min(len(cand_weeks), TOP_N_SEARCH)):
        w = int(cand_weeks.loc[i, "week_idx"])
        ts = pd.to_datetime(cand_weeks.loc[i, "week_start_ts"])
        sample_idx = int(w - encoder_len_weeks)

        if sample_idx < 0:
            continue

        pack = extract_one_sample(df_xlsx, sample_idx, model_base)
        if pack is None:
            continue

        picks.append({
            "week_idx": w,
            "week_start_ts": ts,
            "sample_index": sample_idx,
            "shock_metric": float(cand_weeks.loc[i, "dV_metric"]),
        })

        if len(picks) >= top_k:
            break

    return picks


def compute_load_shock_from_xlsx(df_xlsx: pd.DataFrame, meta: dict, model_base: str):
    dfb = df_xlsx[df_xlsx["model_name"] == model_base].copy()
    if dfb.empty:
        raise ValueError(f"[ERR] No rows for model_base='{model_base}' in XLSX.")

    if "feature_name" in dfb.columns:
        dfb0 = dfb[dfb["feature_name"] == "load"].copy()
        if not dfb0.empty:
            dfb = dfb0

    sample_ids = sorted(dfb["sample_index"].dropna().unique().tolist())

    out = []
    for sid in sample_ids:
        pack = extract_one_sample(df_xlsx, int(sid), model_base)
        if pack is None:
            continue

        pack = denorm_pack_load(pack, meta)
        hist = pack["hist"]
        true = pack["true"]

        if len(true) < 2:
            continue

        within = float(np.max(np.abs(np.diff(true))))
        boundary = float(abs(true[0] - hist[-1])) if len(hist) > 0 else 0.0
        metric = max(within, boundary)

        out.append({
            "sample_index": int(sid),
            "dL_metric": metric,
            "dL_within": within,
            "dL_boundary": boundary,
        })

    if not out:
        return pd.DataFrame()

    return pd.DataFrame(out).sort_values("dL_metric", ascending=False).reset_index(drop=True)


# ============================================================
# Plot
# ============================================================
def plot_one_week(
    *,
    df_xlsx: pd.DataFrame,
    sample_index: int,
    decoder_week_start_ts: pd.Timestamp,
    tag: str,
    out_dir: str,
    meta: dict,
    load_unit: str,
    temp_unit: str,
    model_base: str,
    csv_path: str,
    xfmr: int,
    xlsx_tag: str,
    save_fig: bool = True,
    show_fig: bool = True,
):
    base = extract_one_sample(df_xlsx, sample_index, model_base)
    if base is None:
        raise ValueError(f"[ERR] sample_index={sample_index} not found for model={model_base}")

    base = denorm_pack_load(base, meta)

    def get_max_step(p):
        vals = []
        if len(p["x_h"]):
            vals.append(int(np.max(p["x_h"])))
        if len(p["x_t"]):
            vals.append(int(np.max(p["x_t"])))
        if len(p["x_p"]):
            vals.append(int(np.max(p["x_p"])))
        return max(vals) if vals else 0

    max_step = get_max_step(base)
    total_len = max_step + 1
    if total_len <= 1:
        print(f"[WARN] total_len={total_len} too small. Skip sample={sample_index}")
        return None

    history_start = pd.to_datetime(decoder_week_start_ts) - pd.Timedelta(hours=168)
    full_time = pd.date_range(start=history_start, periods=total_len, freq="h")

    def to_dt(x_steps):
        if len(x_steps) == 0:
            return []
        x_steps = np.asarray(x_steps).astype(int)
        x_steps = np.clip(x_steps, 0, total_len - 1)
        return full_time[x_steps]

    temp_time, temp_vals = load_temp_from_csv(csv_path, xfmr, history_start, total_len)

    fig, ax = plt.subplots(figsize=(13, 4.2))

    # Load curves
    if len(base["x_h"]) > 0:
        ax.plot(to_dt(base["x_h"]), base["hist"], color="black", linewidth=1.6, label="History")

    if len(base["x_t"]) > 0:
        ax.plot(to_dt(base["x_t"]), base["true"], color="red", linestyle="--", linewidth=1.6, label="True")

    if len(base["x_p"]) > 0:
        ax.plot(to_dt(base["x_p"]), base["pred"], color="blue", linewidth=1.7, alpha=0.95, label="Base (mean)")
        if len(base["std"]) == len(base["pred"]) and len(base["std"]) > 0:
            xp = to_dt(base["x_p"])
            ax.fill_between(
                xp,
                base["pred"] - base["std"],
                base["pred"] + base["std"],
                color="blue",
                alpha=0.15,
                label="Base (±1σ)"
            )

    # history / forecast boundary
    if total_len > 168:
        ax.axvline(full_time[167], color="gray", linestyle="--", linewidth=1.0, alpha=0.7)

    ax.set_ylabel(f"Load ({load_unit})")
    ax.set_xlabel("Date")
    ax.grid(alpha=0.25)

    # Time format
    ax.xaxis.set_major_locator(mdates.AutoDateLocator())
    ax.xaxis.set_major_formatter(mdates.DateFormatter("%m-%d\n%H:%M"))

    # Temperature axis
    ax2 = ax.twinx()
    if len(temp_time) > 168:
        ax2.plot(temp_time[:168], temp_vals[:168], linestyle=":", linewidth=1.1, alpha=0.55, label="Temp (hist)")
        ax2.plot(temp_time[168:], temp_vals[168:], linestyle=":", linewidth=1.2, alpha=0.85, label="Temp (fore)")
    else:
        ax2.plot(temp_time, temp_vals, linestyle=":", linewidth=1.1, alpha=0.75, label="Temp")

    ax2.set_ylabel(f"Temperature ({temp_unit})")

    # Keep load lines in front
    ax.set_zorder(ax2.get_zorder() + 1)
    ax.patch.set_visible(False)

    # Title
    ax.set_title(
        f"{tag} | XFMR={xfmr} | week_start={pd.to_datetime(decoder_week_start_ts).date()} | sample={sample_index}\n"
        f"{xlsx_tag} | model={model_base}"
    )

    # Legend
    h1, l1 = ax.get_legend_handles_labels()
    h2, l2 = ax2.get_legend_handles_labels()
    ax.legend(h1 + h2, l1 + l2, loc="upper left", fontsize=9, framealpha=0.9)

    plt.tight_layout()

    out_png = None
    if save_fig:
        week_str = str(pd.to_datetime(decoder_week_start_ts).date())
        safe_tag = tag.replace(" ", "_")
        out_png = os.path.join(
            out_dir,
            f"{xlsx_tag}__{safe_tag}__xfmr{xfmr}__week{week_str}__sample{sample_index}.png"
        )
        plt.savefig(out_png, dpi=220, bbox_inches="tight")
        print(f"[✓] Saved: {out_png}")

    if show_fig:
        plt.show()
    else:
        plt.close(fig)

    return out_png


