        peak_warmup_epochs=current_peak_warm,
        grad_clip_norm=1.0,
        logvar_min=-10.0,
        logvar_max=5.0,
        load_scale=load_scale,
        topk_k=V2_TOPK_PEAK_K,
        start_epoch=start_epoch,
        best_train_init=best_train_init,
        best_epoch_init=best_epoch_init,
    )
    print(f"[✓] Training stage finished.\n")

    # ============================================================
    # 3) Eval best model on XFMR + export XLSX
    # ============================================================
    print(f"[EVAL] Evaluating BASE model on XFMR={EVAL_XFMR} ...")

    model_base = VariationalSeq2Seq_meta(
        xprime_dim=xprime_dim,
        input_dim=input_dim,
        hidden_size=hidden_dim,
        latent_size=latent_dim,
        output_len=output_len,
        n_externals=n_externals,
        output_dim=output_dim,
        num_layers=num_layers,
        dropout=0.1,
        thermal_indices=thermal_indices,
        workday_index=workday_index,
        season_index=season_index,
    ).to(device)

    if os.path.exists(CKPT_WEIGHTS_BEST):
        state_base = torch.load(CKPT_WEIGHTS_BEST, map_location=device)
        model_base.load_state_dict(state_base, strict=True)
        print(f"[✓] BASE weights loaded from {CKPT_WEIGHTS_BEST}")
    elif os.path.exists(CKPT_FULL_BEST):
        ckpt = torch.load(CKPT_FULL_BEST, map_location=device)
        model_base.load_state_dict(ckpt["model_state_dict"], strict=True)
        print(f"[✓] BASE weights loaded from full ckpt {CKPT_FULL_BEST}")
    else:
        raise FileNotFoundError("No trained checkpoint found for evaluation.")

    evaluate_model(
        model=model_base,
        test_loader=test_loader_eval,
        loss_fn=nn.MSELoss(),
        device=device,
        data_name=f"{data_name}_xfmr{EVAL_XFMR}_{TAG}",
        model_name=f"VAE_BASE_{TAG}",
        data_export_list=plot_data_frames,
    )

    if plot_data_frames:
        final_plot_df = pd.concat(plot_data_frames, ignore_index=True)
        final_plot_df["XFMR"] = int(EVAL_XFMR)
        final_plot_df.to_excel(XLSX_EXPORT_PATH, index=False)
        print(f"[✓] Plot data saved to {XLSX_EXPORT_PATH}")
    else:
        print("[WARN] No plot_data_frames collected; XLSX not saved.")
