# Train
# ============================================================

def train_model_v2(
    model,
    train_loader,
    total_epochs,
    lr,
    device,
    top_k=2,
    kl_weight=0.001,
    warmup_epochs=10,
    save_path_weights_best="best_model_weights.pt",
    save_path_full_best="best_model_full_best.pt",
    save_path_full_latest="latest_model_full.pt",
    optimizer=None,
    thr_frac: float = 0.90,
    tau: float = 0.03,
    q_upper: float = 0.95,
    softarg_temp: float = 0.05,
    lam_thr: float = 0.05,
    lam_q: float = 0.04,
    lam_time: float = 0.01,
    lam_amp: float = 0.03,
    lam_topk: float = 0.01,
    load_scale: float = 1.0,
    peak_warmup_epochs: int = 150,
    grad_clip_norm: float = 1.0,
    logvar_min: float = -10.0,
    logvar_max: float = 5.0,
    topk_k: int = 8,
    start_epoch: int = 1,
    best_train_init: float = float("inf"),
    best_epoch_init: int = -1,
):
    if optimizer is None:
        optimizer = AdamW(model.parameters(), lr=lr, weight_decay=1e-4)

    best_train = best_train_init
    best_epoch = best_epoch_init

    if start_epoch > total_epochs:
        print(f"[INFO] start_epoch={start_epoch} > total_epochs={total_epochs}. Nothing to train.")
        return model

    for ep in range(start_epoch, total_epochs + 1):
        model.train()
        running = 0.0
        skipped = 0
        sum_parts = {
            "nll": 0.0, "thr": 0.0, "q": 0.0, "time": 0.0,
            "amp": 0.0, "topk": 0.0, "kl": 0.0
        }
        cnt_parts = 0

        w_peak = 1.0 if (peak_warmup_epochs is None or peak_warmup_epochs <= 0) else min(1.0, ep / float(peak_warmup_epochs))
        lam_thr_ep = lam_thr * w_peak
        lam_q_ep = lam_q * w_peak
        lam_time_ep = lam_time * w_peak
        lam_amp_ep = lam_amp * w_peak
        lam_topk_ep = lam_topk * w_peak

        for (enc_l, enc_ext, dec_l, dec_ext, tgt) in train_loader:
            enc_l, enc_ext, dec_l, dec_ext, tgt = (
                enc_l.to(device),
                enc_ext.to(device),
                dec_l.to(device),
                dec_ext.to(device),
                tgt.to(device),
            )

            optimizer.zero_grad()

            mu_preds, logvar_preds, mu_z, logvar_z = model(
                enc_l, enc_ext, dec_l, dec_ext,
                epoch=ep, top_k=top_k, warmup_epochs=warmup_epochs
            )

            loss_main, parts = v7_peak_fidelity_loss(
                mu_preds, logvar_preds, tgt,
                thr_frac=thr_frac,
                tau=tau,
                q_upper=q_upper,
                softarg_temp=softarg_temp,
                lam_thr=lam_thr_ep,
                lam_q=lam_q_ep,
                lam_time=lam_time_ep,
                lam_amp=lam_amp_ep,
                lam_topk=lam_topk_ep,
                load_scale=load_scale,
                logvar_min=logvar_min,
                logvar_max=logvar_max,
                topk_k=topk_k,
                return_parts=True,
            )

            if not torch.isfinite(loss_main):
                skipped += 1
                continue

            if kl_weight is not None and kl_weight > 0:
                kl = kl_loss(mu_z, logvar_z)
            else:
                kl = torch.zeros((), device=device)

            loss = loss_main + kl_weight * kl
            if not torch.isfinite(loss):
                skipped += 1
                continue

            sum_parts["nll"] += parts["nll"]
            sum_parts["thr"] += parts["thr"]
            sum_parts["q"] += parts["q"]
            sum_parts["time"] += parts["time"]
            sum_parts["amp"] += parts["amp"]
            sum_parts["topk"] += parts["topk"]
            sum_parts["kl"] += float(kl.detach().cpu())
            cnt_parts += 1

            loss.backward()
            if grad_clip_norm and grad_clip_norm > 0:
                torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=grad_clip_norm)
            optimizer.step()

            running += loss.item() * enc_l.size(0)

        denom = max(1, (len(train_loader.dataset) - skipped * train_loader.batch_size))
        avg = running / denom

        # latest for resume
        save_full_checkpoint(save_path_full_latest, model, optimizer, ep, best_train, best_epoch)

        # IMPORTANT: do not save best before warm-up finishes
        can_update_best = (ep >= peak_warmup_epochs)
        if can_update_best and avg < best_train:
            best_train = avg
            best_epoch = ep
            save_weights_only(save_path_weights_best, model)
            save_full_checkpoint(save_path_full_best, model, optimizer, ep, best_train, best_epoch)
            print(f"✅ [BASE v2] Saved best model at epoch {ep} | loss {best_train:.6f}")

        if ep == start_epoch or ep % 5 == 0 or ep == total_epochs:
            best_str = f"{best_train:.6f} (ep {best_epoch})" if best_epoch >= 0 else "N/A (warm-up phase)"
            print(
                f"[BASE v2] Epoch {ep:3d}/{total_epochs} | "
                f"train loss: {avg:.6f} | best: {best_str} | "
                f"lam_thr={lam_thr_ep:.3f} lam_q={lam_q_ep:.3f} "
                f"lam_time={lam_time_ep:.3f} lam_amp={lam_amp_ep:.3f} "
                f"lam_topk={lam_topk_ep:.3f} | skipped={skipped}"
            )
            if cnt_parts > 0:
                avg_nll = sum_parts["nll"] / cnt_parts
                avg_thr = sum_parts["thr"] / cnt_parts
                avg_q = sum_parts["q"] / cnt_parts
                avg_time = sum_parts["time"] / cnt_parts
                avg_amp = sum_parts["amp"] / cnt_parts
                avg_topk = sum_parts["topk"] / cnt_parts
                avg_kl = sum_parts["kl"] / cnt_parts
                print(
                    f"[PARTS] nll={avg_nll:.4f} thr={avg_thr:.4f} q={avg_q:.4f} "
                    f"time={avg_time:.4f} amp={avg_amp:.4f} topk={avg_topk:.4f} kl={avg_kl:.4f} | weighted: "
                    f"+{lam_thr_ep * avg_thr:.4f} +{lam_q_ep * avg_q:.4f} "
                    f"+{lam_time_ep * avg_time:.4f} +{lam_amp_ep * avg_amp:.4f} "
                    f"+{lam_topk_ep * avg_topk:.4f} +{kl_weight * avg_kl:.4f}"
                )

    print(f"\n🏁 [BASE v2] Done. Best epoch {best_epoch} | loss {best_train:.6f}")
    return model


