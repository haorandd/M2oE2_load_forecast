# ============================================================
# Peak-oriented losses
# ============================================================

def soft_threshold_mask(y_true: torch.Tensor, thr_frac: float, tau: float):
    B = y_true.size(0)
    y_flat = y_true.reshape(B, -1)
    y_max = y_flat.max(dim=1, keepdim=True).values
    thr = thr_frac * y_max
    thr = thr.view(B, 1, 1)
    w = torch.sigmoid((y_true - thr) / (tau + 1e-12))
    return w, thr


def gaussian_nll_pointwise(mu, logvar, y, logvar_min=-10.0, logvar_max=5.0):
    logvar = logvar.clamp(min=logvar_min, max=logvar_max)
    var = logvar.exp()
    log2pi = math.log(2.0 * math.pi)
    nll = 0.5 * (logvar + log2pi + (y - mu) ** 2 / (var + 1e-12))
    return nll, logvar


def softargmax_time(y, temp: float):
    B, T = y.shape
    idx = torch.arange(T, device=y.device, dtype=y.dtype).view(1, T)
    p = torch.softmax(y / (temp + 1e-12), dim=1)
    t = (p * idx).sum(dim=1)
    return t


def peak_amplitude_loss(mu, y, load_scale: float = 1.0):
    B = y.size(0)
    mu_flat = mu.reshape(B, -1)
    y_flat = y.reshape(B, -1)

    mu_peak = mu_flat.max(dim=1).values
    y_peak = y_flat.max(dim=1).values
    return ((mu_peak - y_peak) ** 2).mean() * (load_scale ** 2)


def topk_peak_loss(mu, y, k: int = 8, load_scale: float = 1.0):
    B = y.size(0)
    mu_flat = mu.reshape(B, -1)
    y_flat = y.reshape(B, -1)

    k = min(k, mu_flat.size(1))
    mu_topk = torch.topk(mu_flat, k=k, dim=1).values
    y_topk = torch.topk(y_flat, k=k, dim=1).values
    return ((mu_topk - y_topk) ** 2).mean() * (load_scale ** 2)


def v7_peak_fidelity_loss(
    mu_preds: torch.Tensor,
    logvar_preds: torch.Tensor,
    tgt: torch.Tensor,
    *,
    thr_frac: float = 0.90,
    tau: float = 0.03,
    q_upper: float = 0.95,
    softarg_temp: float = 0.05,
    lam_thr: float = 3.0,
    lam_q: float = 1.0,
    lam_time: float = 0.1,
    lam_amp: float = 0.2,
    lam_topk: float = 0.1,
    load_scale: float = 1.0,
    logvar_min: float = -10.0,
    logvar_max: float = 5.0,
    topk_k: int = 8,
    return_parts: bool = False,
):
    mu = mu_preds.squeeze(-1)
    y = tgt.squeeze(-1)
    logv = logvar_preds.squeeze(-1)

    nll, logv_clamped = gaussian_nll_pointwise(mu, logv, y, logvar_min, logvar_max)
    sigma = (0.5 * logv_clamped).exp()

    w_peak, _ = soft_threshold_mask(y, thr_frac=thr_frac, tau=tau)

    err2 = (mu - y).pow(2)
    L_thr = (w_peak * err2).sum() / (w_peak.sum() + 1e-12)

    zq = gaussian_icdf(q_upper, device=mu.device)
    yq = mu + zq * sigma
    pl = pinball_loss(y, yq, q_upper)
    L_q = (w_peak * pl).sum() / (w_peak.sum() + 1e-12)

    L_thr = L_thr * (load_scale ** 2)
    L_q = L_q * load_scale

    B = y.size(0)
    y_flat = y.reshape(B, -1)
    mu_flat = mu.reshape(B, -1)
    t_true = softargmax_time(y_flat, temp=softarg_temp)
    t_pred = softargmax_time(mu_flat, temp=softarg_temp)
    T = y_flat.size(1)
    L_time = (t_pred - t_true).abs().mean() / (T + 1e-12)

    L_amp = peak_amplitude_loss(mu, y, load_scale=load_scale)
    L_topk = topk_peak_loss(mu, y, k=topk_k, load_scale=load_scale)

    nll_mean = nll.mean()
    loss = (
        nll_mean
        + lam_thr * L_thr
        + lam_q * L_q
        + lam_time * L_time
        + lam_amp * L_amp
        + lam_topk * L_topk
    )

    if return_parts:
        parts = {
            "nll": float(nll_mean.detach().cpu()),
            "thr": float(L_thr.detach().cpu()),
            "q": float(L_q.detach().cpu()),
            "time": float(L_time.detach().cpu()),
            "amp": float(L_amp.detach().cpu()),
            "topk": float(L_topk.detach().cpu()),
        }
        return loss, parts

    return loss


# ============================================================
# Checkpoint helpers
# ============================================================

def save_full_checkpoint(
    save_path_full: str,
    model: nn.Module,
    optimizer: torch.optim.Optimizer,
    epoch: int,
    best_train: float,
    best_epoch: int,
):
    ckpt = {
        "epoch": epoch,
        "model_state_dict": model.state_dict(),
        "optimizer_state_dict": optimizer.state_dict(),
        "best_train": best_train,
        "best_epoch": best_epoch,
        "rng_state": get_rng_state(),
    }
    torch.save(ckpt, save_path_full)


def save_weights_only(save_path_weights: str, model: nn.Module):
    torch.save(model.state_dict(), save_path_weights)


def load_model_flexible(
    path: str,
    model: nn.Module,
    optimizer: torch.optim.Optimizer = None,
    device: torch.device = None,
):
    obj = torch.load(path, map_location=device)

    if isinstance(obj, dict) and "model_state_dict" in obj:
        model.load_state_dict(obj["model_state_dict"], strict=True)
        if optimizer is not None and "optimizer_state_dict" in obj:
            optimizer.load_state_dict(obj["optimizer_state_dict"])
        if "rng_state" in obj:
            set_rng_state(obj["rng_state"])
        return {
            "is_full_ckpt": True,
            "epoch": int(obj.get("epoch", 0)),
            "best_train": float(obj.get("best_train", float("inf"))),
            "best_epoch": int(obj.get("best_epoch", -1)),
        }

    model.load_state_dict(obj, strict=True)
    return {
        "is_full_ckpt": False,
        "epoch": None,
        "best_train": None,
        "best_epoch": None,
    }


